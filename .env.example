# Required — Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required — site URL (use your Vercel URL after first deploy, then your custom domain)
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Required for admin emails / contact notifications
ADMIN_EMAIL=
FROM_EMAIL=
RESEND_API_KEY=

# Optional — contact page
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/27824544655

# EFT bank details (shown in cart / checkout when EFT is selected)
EFT_BANK_NAME=
EFT_ACCOUNT_NAME=
EFT_ACCOUNT_NUMBER=
EFT_BRANCH_CODE=
EFT_ACCOUNT_TYPE=
EFT_POP_EMAIL=
ORDERS_EMAIL=

# Payment provider: payfast | peach
PAYMENT_PROVIDER=payfast

# PayFast (update RETURN/CANCEL/NOTIFY URLs to your production domain)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_RETURN_URL=https://your-project.vercel.app/portal/checkout/return
PAYFAST_CANCEL_URL=https://your-project.vercel.app/portal/cart
PAYFAST_NOTIFY_URL=https://your-project.vercel.app/api/webhooks/payments
PAYFAST_HOST=https://www.payfast.co.za/eng/process

# Peach (if PAYMENT_PROVIDER=peach)
PEACH_ENTITY_ID=
PEACH_ACCESS_TOKEN=
PEACH_RETURN_URL=https://your-project.vercel.app/portal/checkout/return
PEACH_API_BASE=https://testsecure.peachpayments.com
PEACH_WEBHOOK_SECRET=

# Google Sheets (application form export — optional)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
